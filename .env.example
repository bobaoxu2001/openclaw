# ============================================================
# OpenClaw Deployment Configuration
# Copy this file to .env and fill in the values
# ============================================================

# --- Gateway Authentication ---
# Auto-generated by deploy.sh, or set your own token
OPENCLAW_GATEWAY_TOKEN=

# --- LLM API Keys (configure at least one) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MINIMAX_API_KEY=

# --- OpenClaw Version ---
# Git branch or tag to build from (default: main)
OPENCLAW_VERSION=main

# --- Networking ---
# Gateway web UI port (default: 18789)
OPENCLAW_GATEWAY_PORT=18789
# Bridge port for companion apps (default: 18790)
OPENCLAW_BRIDGE_PORT=18790
# Bind mode: "lan" (all interfaces) or "localhost" (local only)
OPENCLAW_GATEWAY_BIND=lan

# --- Data Directories ---
# Where OpenClaw stores its configuration
OPENCLAW_CONFIG_DIR=./data/config
# Where OpenClaw stores workspace files
OPENCLAW_WORKSPACE_DIR=./data/workspace

# --- Logging ---
# Log level: debug, info, warn, error
OPENCLAW_LOG_LEVEL=info

# --- Optional: Build-time Customization ---
# Extra apt packages to install in the image (space-separated)
OPENCLAW_DOCKER_APT_PACKAGES=
# Set to "1" to install Chromium for browser automation
OPENCLAW_INSTALL_BROWSER=
# Use a pre-built image instead of building locally
# OPENCLAW_IMAGE=openclaw:local
